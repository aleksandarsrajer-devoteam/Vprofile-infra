[Unit]
Description=Apache Tomcat 10
After=network.target

[Service]
Type=simple
User=tomcat
Group=tomcat

Environment="JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64"
Environment="CATALINA_PID=/tmp/tomcat.pid"
Environment="CATALINA_HOME={{ tomcat_home }}"
Environment="CATALINA_BASE={{ tomcat_home }}"

# This file is written at boot by the startup script after fetching the
# DB password from Secret Manager. The '-' prefix means systemd silently
# skips it if it doesn't exist yet (safe during Packer build phase).
EnvironmentFile=-/etc/tomcat/app.env

ExecStart={{ tomcat_home }}/bin/catalina.sh run
ExecStop={{ tomcat_home }}/bin/catalina.sh stop 15 -force
RestartSec=10
Restart=always

[Install]
WantedBy=multi-user.target
